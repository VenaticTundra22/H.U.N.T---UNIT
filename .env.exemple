# Token secret de ton bot Discord (récupérable sur le portail développeur Discord)
DISCORD_TOKEN=ton_token_ici

# ID de ton serveur Discord (optionnel)
# - Si renseigné : Le bot passe en MODE DEV (commandes créées instantanément, uniquement sur ce serveur).
# - Si vide ou supprimé : Le bot passe en MODE PROD (commandes globales pour tous les serveurs, active le badge APP).
GUILD_ID=ton_id_serveur_ici